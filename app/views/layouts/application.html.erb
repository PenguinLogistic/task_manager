<!DOCTYPE html>
<html>
  <head>
    <title>TaskManager</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "application", "tailwind", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="min-h-screen bg-gradient-to-br from-violet-50 to-indigo-100">
    <nav class="bg-white shadow-sm border-b border-violet-100">
      <div class="max-w-4xl mx-auto px-4 py-4 flex items-center justify-between">
        <a href="/" class="text-2xl font-bold bg-gradient-to-r from-violet-600 to-indigo-600 bg-clip-text text-transparent">
          ✅ TaskManager
        </a>
        <%= link_to "New Task", new_task_path, class: "bg-gradient-to-r from-violet-500 to-indigo-500 text-white px-4 py-2 rounded-full text-sm font-semibold hover:opacity-90 transition" %>
      </div>
    </nav>

    <main class="max-w-4xl mx-auto px-4 py-8">
      <% if notice.present? %>
        <div class="mb-4 bg-green-100 border border-green-300 text-green-800 px-4 py-3 rounded-xl">
          <%= notice %>
        </div>
      <% end %>
      <%= yield %>
    </main>
  </body>
</html>