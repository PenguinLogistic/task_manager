<div class="bg-white rounded-2xl shadow-sm border border-violet-100 p-6">
  <%= form_with(model: task) do |form| %>
    <% if task.errors.any? %>
      <div class="mb-4 bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-xl">
        <p class="font-semibold"><%= pluralize(task.errors.count, "error") %> prevented this task from being saved:</p>
        <ul class="mt-2 list-disc list-inside text-sm">
          <% task.errors.each do |error| %>
            <li><%= error.full_message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="space-y-5">
      <div>
        <%= form.label :title, class: "block text-sm font-semibold text-gray-700 mb-1" %>
        <%= form.text_field :title, class: "w-full border border-gray-200 rounded-xl px-4 py-2.5 text-gray-800 focus:outline-none focus:ring-2 focus:ring-violet-400", placeholder: "What needs to be done?" %>
      </div>

      <div>
        <%= form.label :description, class: "block text-sm font-semibold text-gray-700 mb-1" %>
        <%= form.text_area :description, rows: 4, class: "w-full border border-gray-200 rounded-xl px-4 py-2.5 text-gray-800 focus:outline-none focus:ring-2 focus:ring-violet-400", placeholder: "Add some details..." %>
      </div>

      <div>
        <%= form.label :due_date, class: "block text-sm font-semibold text-gray-700 mb-1" %>
        <%= form.date_field :due_date, class: "w-full border border-gray-200 rounded-xl px-4 py-2.5 text-gray-800 focus:outline-none focus:ring-2 focus:ring-violet-400" %>
      </div>

      <div class="flex items-center gap-3">
        <%= form.check_box :completed, class: "w-4 h-4 accent-violet-500" %>
        <%= form.label :completed, "Mark as completed", class: "text-sm font-semibold text-gray-700" %>
      </div>

      <div>
        <%= form.submit class: "w-full bg-gradient-to-r from-violet-500 to-indigo-500 text-white font-semibold py-2.5 rounded-xl hover:opacity-90 transition cursor-pointer" %>
      </div>
    </div>
  <% end %>
</div>