<div class="bg-white rounded-2xl shadow-sm border border-violet-100 p-8 max-w-2xl mx-auto">
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-bold text-gray-800"><%= @task.title %></h1>
    <span class="<%= @task.completed ? 'bg-green-100 text-green-700' : 'bg-amber-100 text-amber-700' %> text-xs font-semibold px-3 py-1 rounded-full">
      <%= @task.completed ? 'Done' : 'In Progress' %>
    </span>
  </div>

  <div class="space-y-4 text-gray-600">
    <div>
      <p class="text-xs font-semibold uppercase tracking-wide text-gray-400 mb-1">Description</p>
      <p><%= @task.description.present? ? @task.description : "No description provided." %></p>
    </div>

    <div>
      <p class="text-xs font-semibold uppercase tracking-wide text-gray-400 mb-1">Due Date</p>
      <p><%= @task.due_date.present? ? @task.due_date.strftime("%B %d, %Y") : "No due date set." %></p>
    </div>
  </div>

  <div class="flex gap-3 mt-8">
    <%= link_to "Edit", edit_task_path(@task), class: "bg-gradient-to-r from-violet-500 to-indigo-500 text-white px-5 py-2 rounded-full text-sm font-semibold hover:opacity-90 transition" %>
    <%= link_to "Delete", @task, data: { turbo_method: :delete, turbo_confirm: "Are you sure?" }, class: "bg-red-50 text-red-500 px-5 py-2 rounded-full text-sm font-semibold hover:bg-red-100 transition" %>
    <%= link_to "Back to Tasks", root_path, class: "bg-gray-50 text-gray-600 px-5 py-2 rounded-full text-sm font-semibold hover:bg-gray-100 transition" %>
  </div>
</div>