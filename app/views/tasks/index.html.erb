<div class="mb-6">
  <h1 class="text-3xl font-bold text-gray-800">My Tasks</h1>
  <p class="text-gray-500 mt-1">Stay on top of everything</p>
</div>

<div class="space-y-3">
  <div class="mb-6 flex flex-wrap gap-2 items-center justify-between">
    <div class="flex gap-2">
      <%= link_to "All", tasks_path, class: "px-4 py-1.5 rounded-full text-sm font-semibold #{params[:status].blank? ? 'bg-violet-100 text-violet-700 border border-violet-200' : 'bg-white text-gray-500 border border-gray-200 hover:bg-gray-50'}" %>
      <%= link_to "In Progress", tasks_path(status: "in_progress"), class: "px-4 py-1.5 rounded-full text-sm font-semibold #{params[:status] == 'in_progress' ? 'bg-amber-100 text-amber-700 border border-amber-200' : 'bg-white text-gray-500 border border-gray-200 hover:bg-gray-50'}" %>
      <%= link_to "Done", tasks_path(status: "completed"), class: "px-4 py-1.5 rounded-full text-sm font-semibold #{params[:status] == 'completed' ? 'bg-green-100 text-green-700 border border-green-200' : 'bg-white text-gray-500 border border-gray-200 hover:bg-gray-50'}" %>
    </div>

    <div class="flex gap-2">
      <%= link_to "Due Date ↑", tasks_path(status: params[:status], sort: "due_date_asc"), class: "px-4 py-1.5 rounded-full text-sm font-semibold #{params[:sort] == 'due_date_asc' ? 'bg-indigo-100 text-indigo-700 border border-indigo-200' : 'bg-white text-gray-500 border border-gray-200 hover:bg-gray-50'}" %>
      <%= link_to "Due Date ↓", tasks_path(status: params[:status], sort: "due_date_desc"), class: "px-4 py-1.5 rounded-full text-sm font-semibold #{params[:sort] == 'due_date_desc' ? 'bg-indigo-100 text-indigo-700 border border-indigo-200' : 'bg-white text-gray-500 border border-gray-200 hover:bg-gray-50'}" %>
    </div>
  </div>

  <% @tasks.each do |task| %>
    <div class="<%= task.overdue? ? 'bg-red-50 border-red-200' : 'bg-white border-violet-100' %> rounded-2xl shadow-sm border p-5 flex items-center justify-between hover:shadow-md transition">
      <div class="flex items-center gap-4">
        <div class="<%= task.completed ? 'bg-green-100' : 'bg-violet-100' %> rounded-full w-3 h-3"></div>
        <div>
          <p class="font-semibold text-gray-800 <%= 'line-through text-gray-400' if task.completed %>">
            <%= task.title %>
          </p>
          <p class="text-sm mt-0.5 <%= task.overdue? ? 'text-red-400 font-semibold' : 'text-gray-400' %>">
            <%= task.due_date.present? ? task.due_date.strftime("%B %d, %Y") : "No due date" %>
            <%= " - Overdue" if task.overdue? %>
          </p>
        </div>
      </div>

      <div class="flex items-center gap-2">
        <span class="<%= task.completed ? 'bg-green-100 text-green-700' : 'bg-amber-100 text-amber-700' %> text-xs font-semibold px-3 py-1 rounded-full">
          <%= task.completed ? 'Done' : 'In Progress' %>
        </span>
        <%= link_to "View", task, class: "text-sm text-violet-600 hover:underline font-medium" %>
        <%= link_to "Edit", edit_task_path(task), class: "text-sm text-indigo-600 hover:underline font-medium" %>
        <%= link_to "Delete", task, data: { turbo_method: :delete, turbo_confirm: "Are you sure?" }, class: "text-sm text-red-400 hover:underline font-medium" %>
      </div>
    </div>
  <% end %>

  <% if @tasks.empty? %>
    <div class="text-center py-20 text-gray-400">
      <p class="text-lg font-medium">No tasks yet!</p>
      <p class="text-sm mt-1">Click "New Task" to get started.</p>
    </div>
  <% end %>
</div>